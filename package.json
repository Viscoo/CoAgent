{
  "name": "coagent",
  "version": "0.2.0",
  "description": "A lightweight multi-agent orchestration layer for OpenCode.",
  "type": "module",
  "bin": {
    "coagent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "coagent": "node dist/cli.js",
    "dev": "npx tsx src/cli.ts",
    "test": "bun test",
    "check": "tsc -p tsconfig.json --noEmit",
    "postinstall": "node scripts/setup-opencode.mjs"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.17.17",
    "adm-zip": "^0.5.18",
    "blessed": "^0.1.81",
    "opencode-ai": "^1.17.17",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/node": "^22.13.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=22.0.0"
  }
}
